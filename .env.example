# Environment Variable Configurations for Quran RAG
# Rename this file to .env and add your private credentials.

# OpenAI API credentials (used for gpt-4o-mini generation, query expansion, and Ragas)
OPENAI_API_KEY=your_openai_api_key_here

# Cohere API credentials (used for Cohere rerank API)
COHERE_API_KEY=your_cohere_api_key_here

# Gemini API credentials (used for gemini-2.5-flash generation and query expansion)
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEY=your_gemini_api_key_here
